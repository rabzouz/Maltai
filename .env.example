# Maltai - exemple de configuration. Copier en .env (optionnel).
# Les valeurs par defaut fonctionnent en local sans rien configurer.

APP_BIND=127.0.0.1
APP_PORT=7000

# Provider par defaut cree au premier demarrage (compatible OpenAI).
DEFAULT_PROVIDER_NAME=Ollama local
DEFAULT_BASE_URL=http://localhost:11434/v1
DEFAULT_API_KEY=ollama
DEFAULT_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# Base de donnees
# DATABASE_URL=sqlite:///./data/app.db

# Auth (pas encore branchee dans le MVP - cf. ROADMAP)
AUTH_ENABLED=true
LOCALHOST_BYPASS=false
SECURE_COOKIES=false
MALTAI_REGISTRATION_ENABLED=true

# --- Métadonnées de déploiement (optionnel, utile Docker/Coolify) ---
# Si l'image Docker ne contient pas .git, les outils admin git_* affichent ces valeurs.
# MALTAI_GIT_BRANCH=main
# MALTAI_GIT_COMMIT=abcdef123456

# --- Mémoire vectorielle ---
MEMORY_ENABLED=true
MEMORY_TOP_K=4
MEMORY_MIN_SCORE=0.3
# Modèle d'embeddings du provider seedé (Ollama: nomic-embed-text, mxbai-embed-large…)
DEFAULT_EMBED_MODEL=nomic-embed-text

# --- Compression de contexte style Headroom ---
# Compresse automatiquement les grosses sorties d'outils avant retour au LLM.
MALTAI_CONTEXT_COMPRESSION=1
MALTAI_CONTEXT_COMPRESS_MIN_CHARS=5000
MALTAI_CONTEXT_COMPRESS_MAX_CHARS=3500

# --- Stripe Checkout (optionnel : plans Premium / credits) ---
# Cree les produits/prix dans Stripe Dashboard, puis colle les Price IDs (price_...).
# En local : APP_PUBLIC_URL=http://localhost:7000
# En prod : APP_PUBLIC_URL=https://maltai.fr
APP_PUBLIC_URL=http://localhost:7000
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
# STRIPE_PREMIUM_YEARLY_PRICE_ID=price_...
# STRIPE_CREDITS_100K_PRICE_ID=price_...
MALTAI_PREMIUM_MONTHLY_CREDITS=100000
MALTAI_PREMIUM_YEARLY_CREDITS=1200000

# --- Provider OpenAI reserve aux utilisateurs Premium ---
# Cette cle reste cote serveur et n'est jamais envoyee au navigateur.
# PREMIUM_OPENAI_API_KEY=sk-...
PREMIUM_OPENAI_NAME=Maltai Premium OpenAI
PREMIUM_OPENAI_BASE_URL=https://api.openai.com/v1
PREMIUM_OPENAI_MODEL=gpt-4o-mini
PREMIUM_OPENAI_EMBED_MODEL=text-embedding-3-small
MALTAI_MANAGED_OPENAI_MONTHLY_USER_TOKEN_LIMIT=100000
MALTAI_MANAGED_OPENAI_MONTHLY_GLOBAL_TOKEN_LIMIT=1000000
MALTAI_MANAGED_OPENAI_MAX_INPUT_TOKENS=12000
MALTAI_MANAGED_OPENAI_MAX_OUTPUT_TOKENS=800

# --- Generation d'images (optionnel) ---
# Endpoint compatible OpenAI /v1/images/generations :
# OpenAI, LocalAI, Stable Diffusion webui (--api), ComfyUI via wrapper OpenAI...
# IMAGE_API_BASE=https://api.openai.com
# IMAGE_API_KEY=sk-...
# IMAGE_MODEL=gpt-image-1
